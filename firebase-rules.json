{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['matricNo', 'name', 'role', 'email'])"
      }
    },

    "sessions": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$sessionId": {
        "token": { ".validate": "newData.isString()" },
        "startTime": { ".validate": "newData.isNumber()" },
        "endTime": { ".validate": "newData.isNumber()" },
        "active": { ".validate": "newData.isBoolean()" },
        "course": { ".validate": "newData.val() === 'IDS111'" }
      }
    },

    "attendance": {
      ".read": "auth != null",
      "$sessionId": {
        "$uid": {
          ".write": "auth != null && auth.uid === $uid",
          ".read": "auth != null",
          "timestamp": { ".validate": "newData.isNumber()" },
          "deviceId": { ".validate": "newData.isString()" },
          "lat": { ".validate": "newData.isNumber()" },
          "lng": { ".validate": "newData.isNumber()" }
        }
      }
    }
  }
}
